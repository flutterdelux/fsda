{
    "name": "app_ui",
    "description": "UI package for the app",
    "version": "0.0.1",
    "publish_to": "none",
    "dependencies": [
        "shimmer",
        "gap",
        "extended_image",
        "flutter_colorpicker",
        "dotted_border",
        "intl"
    ],
    "dependencies_manual": [
        "  flutter:",
        "    sdk: flutter",
        "  app_core:",
        "    path: ../app_core",
        "  app_l10n:",
        "    path: ../app_l10n"
    ],
    "dev_dependencies": [
        "flutter_lints"
    ],
    "dev_dependencies_manual": [
        "  flutter_test:",
        "    sdk: flutter"
    ],
    "flutter": [
        "  uses-material-design: true",
        "  fonts:",
        "  - family: Inter",
        "    fonts:",
        "      - asset: assets/fonts/inter/Inter-Light.ttf",
        "        weight: 300",
        "      - asset: assets/fonts/inter/Inter-Regular.ttf",
        "        weight: 400",
        "      - asset: assets/fonts/inter/Inter-Medium.ttf",
        "        weight: 500",
        "      - asset: assets/fonts/inter/Inter-SemiBold.ttf",
        "        weight: 600",
        "      - asset: assets/fonts/inter/Inter-Bold.ttf",
        "        weight: 700"
    ],
    "post_hooks": [
        "dart pub get"
    ]
}