{
    "name": "app_core",
    "description": "Core package for the app",
    "version": "0.0.1",
    "publish_to": "none",
    "dependencies": [
        "freezed_annotation"
    ],
    "dependencies_manual": [
        "  flutter:",
        "    sdk: flutter"
    ],
    "dev_dependencies": [
        "flutter_lints",
        "build_runner",
        "freezed"
    ],
    "dev_dependencies_manual": [
        "  flutter_test:",
        "    sdk: flutter"
    ],
    "post_hooks": [
        "dart pub get",
        "dart run build_runner build --force-jit --delete-conflicting-outputs"
    ]
}